# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Task API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1

# ── Database (local dev — SQLite) ────────────────────────────────────────────
DATABASE_URL=sqlite:///./task_api.db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── Database (Docker / production — Postgres) ──────────────────────────────────
# DATABASE_URL=postgresql+psycopg2://taskapi:taskapi@db:5432/taskapi
POSTGRES_USER=taskapi
POSTGRES_PASSWORD=taskapi
POSTGRES_DB=taskapi
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Auth (JWT) — CHANGE SECRET_KEY IN PRODUCTION ─────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_REGISTER=5/minute

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Dev seed accounts (created on startup in development) ─────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=user123
